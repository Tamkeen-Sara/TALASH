# Copy this file to .env and fill in your actual keys
# NEVER commit .env to git

# Anthropic API (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# CORE API for conference rankings (free registration at api.core.ac.uk)
CORE_API_KEY=your_core_api_key_here

# Semantic Scholar (optional — increases rate limit)
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key_here

# Email address for polite pool access (OpenAlex, CrossRef)
POLITE_MAILTO=your_email@example.com

# App settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
